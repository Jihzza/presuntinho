    {
      "type": "dialogues",
      "title": "Mini-diálogos",
      "data": {
        "items": [
          {
            "title": "1. A conhecer um colega",
            "lines": [
              {"speaker": "A", "pt": "Olá! Eu sou a Fatma. E tu?", "en": "Hi! I'm Fatma. And you?"},
              {"speaker": "B", "pt": "Olá Fatma! Eu sou o Lucas. Muito prazer.", "en": "Hi Fatma! I'm Lucas. Nice to meet you."},
              {"speaker": "A", "pt": "De onde és?", "en": "Where are you from?"},
              {"speaker": "B", "pt": "Sou do Brasil. E tu?", "en": "I'm from Brazil. And you?"},
              {"speaker": "A", "pt": "Sou da Tunísia.", "en": "I'm from Tunisia."},
              {"speaker": "B", "pt": "Que legal! Bem-vinda à EU Business School.", "en": "Cool! Welcome to EU Business School."}
            ]
          },
          {
            "title": "2. A pedir um café",
            "lines": [
              {"speaker": "A", "pt": "Bom dia! Um café, por favor.", "en": "Good morning! A coffee, please."},
              {"speaker": "B", "pt": "Curto ou longo?", "en": "Short or long?"},
              {"speaker": "A", "pt": "Curto, por favor. Quanto custa?", "en": "Short, please. How much is it?"},
              {"speaker": "B", "pt": "Um euro.", "en": "One euro."},
              {"speaker": "A", "pt": "Aqui tem. Obrigada!", "en": "Here you go. Thanks!"}
            ]
          },
          {
            "title": "3. A pedir indicações",
            "lines": [
              {"speaker": "A", "pt": "Com licença, onde fica a biblioteca?", "en": "Excuse me, where is the library?"},
              {"speaker": "B", "pt": "Vai em frente, depois vira à direita. É o segundo edifício.", "en": "Go straight, then turn right. It's the second building."},
              {"speaker": "A", "pt": "Muito obrigada!", "en": "Thank you very much!"}
            ]
          }
        ]
      }
